# Konfigurasi Pengiriman WhatsApp OTP
# ------------------------------------
# Set KIRIM_OTP ke 'true' untuk mengirim OTP via WhatsApp.
# Set ke 'false' untuk menonaktifkan pengiriman dan menggunakan kode statis '11111' untuk development.
KIRIM_OTP=true

# URL endpoint dari GoWa service
GO_WA_SEND_MESSAGE_URL="http://100.120.227.121:3030/send/message"
